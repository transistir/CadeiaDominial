.claude/command-history.log
.claude/history.jsonl
.claude/debug/
.claude/file-history/
.claude/session-env/
.claude/shell-snapshots/
.claude/todos/
.claude/cache/
.claude/logs/
.claude/stats-*.json
.claude/webui-projects.json
.claude/.env
.claude/state/
.claude/tmp/

