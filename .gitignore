# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
# pnpm-lock.yaml is INTENTIONALLY committed (see PR #25): we need --frozen-lockfile
# in CI for deterministic installs. Other lockfiles remain ignored (we use pnpm only).

# TypeScript
*.tsbuildinfo

# Vite
.vite/
dist/
dist-ssr/
*.local

# Vitest
coverage/
.nyc_output/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Wrangler (Cloudflare)
.wrangler/
wrangler-*toml
.mf/

# Drizzle
drizzle/**/*.snapshot.ts

# Environment (keep .env.example)
.env
.env.local
.env.*.local
.cloudflare.token

