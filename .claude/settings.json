{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git show)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git fetch)",
      "Bash(git checkout*)",
      "Bash(git branch)",
      "Bash(git tag)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(test:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Read(**)",
      "Write(./**/*.md)",
      "Write(./**/*.ts)",
      "Write(./**/*.tsx)",
      "Write(./**/*.js)",
      "Write(./**/*.jsx)",
      "Write(./**/*.json)",
      "Edit(**)"
    ],
    "deny": [
      "Bash(rm -rf)",
      "Bash(rm -fr)",
      "Bash(rm -Rf)",
      "Bash(rm -r)",
      "Bash(rm -f)",
      "Bash(rmdir -s)",
      "Bash(rmdir /s)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ../*)",
      "Bash(rm -rf /**)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf packages/*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard HEAD)",
      "Bash(git reset --hard origin/*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout -- .)",
      "Bash(git checkout -- *)",
      "Bash(git clean -fd)",
      "Bash(git clean -fdx)",
      "Bash(git clean -fx)",
      "Bash(git branch -D)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(git update-ref -d)",
      "Bash(git update-ref --no-deref)",
      "Bash(chmod -R)",
      "Bash(chmod -R 777)",
      "Bash(chmod 777)",
      "Bash(chown -R)",
      "Bash(dd if=)",
      "Bash(dd of=/dev/sd)",
      "Bash(dd of=/dev/nvme)",
      "Bash(mkfs)",
      "Bash(mkfs.*)",
      "Bash(fdisk)",
      "Bash(format)",
      "Bash(curl)",
      "Bash(wget)",
      "Bash(nc -l)",
      "Bash(netcat -l)",
      "Bash(ncat -l)",
      "Bash(ssh)",
      "Bash(scp)",
      "Bash(sftp)",
      "Bash(chmod 000)",
      "Bash(chmod 400 *)",
      "Bash(> /dev/)",
      "Bash(> /dev/sd)",
      "Bash(> /dev/nvme)",
      "Bash(> /etc/)",
      "Bash(> ~/.ssh/)",
      "Bash(> .env)",
      "Bash(> .env.*)",
      "Bash(> secrets/)",
      "Bash(> *.key)",
      "Bash(> *.pem)",
      "Bash(mv ~/.ssh)",
      "Bash(mv /etc/)",
      "Bash(mv /usr/)",
      "Bash(mv /bin/)",
      "Bash(mv /sbin/)",
      "Bash(rm ~/.ssh)",
      "Bash(rm ~/.ssh/*)",
      "Bash(rm /etc/)",
      "Bash(rm .env)",
      "Bash(rm .env.*)",
      "Bash(rm *.key)",
      "Bash(rm *.pem)",
      "Bash(rm secrets/*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(~/.ssh/**)",
      "Read(/etc/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Write(./**/*.key)",
      "Write(./**/*.pem)",
      "Write(~/.ssh/**)",
      "Write(/etc/**)",
      "Bash(npm uninstall)",
      "Bash(pnpm uninstall)",
      "Bash(pnpm remove)",
      "Bash(yarn remove)",
      "Bash(pip uninstall)",
      "Bash(pip3 uninstall)",
      "Bash(brew remove)",
      "Bash(brew unlink)",
      "Bash(sudo)",
      "Bash(su)",
      "Bash(doas)",
      "Write(./node_modules/**)",
      "Write(./.git/**)"
    ]
  }
}
