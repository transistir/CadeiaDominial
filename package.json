{
  "name": "cadeia-dominial",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @cadeia/api dev",
    "dev:web": "pnpm --filter @cadeia/web dev",
    "db:generate": "pnpm --filter @cadeia/api db:generate",
    "db:migrate:local": "pnpm --filter @cadeia/api db:migrate:local",
    "db:studio": "pnpm --filter @cadeia/api db:studio",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "turbo run test:unit",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "test:e2e": "turbo run test:e2e",
    "prepare": "husky install",
    "deploy:api": "pnpm --filter @cadeia/api deploy",
    "deploy:web": "pnpm --filter @cadeia/web deploy"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "pnpm exec eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.60.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
